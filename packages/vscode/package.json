{
  "name": "loom-vscode",
  "displayName": "Loom AI",
  "description": "AI workflow engine: turns your project docs into a structured graph your AI agent reads and writes. 1‑click in VS Code — no CLI, no setup.",
  "version": "1.22.0",
  "publisher": "reslava",
  "license": "MIT",
  "icon": "media/loom.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/reslava/loom"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "mcp",
    "ai-agent",
    "claude-code",
    "workflow-automation",
    "ai",
    "workflow",
    "documentation",
    "markdown",
    "cursor"
  ],
  "activationEvents": [
    "workspaceContains:.loom/**",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "loom",
          "title": "Loom",
          "icon": "media/loom-icon.svg"
        }
      ]
    },
    "views": {
      "loom": [
        {
          "id": "loom.threads",
          "name": "Threads"
        },
        {
          "id": "loom.context",
          "name": "Context"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "loom.threads",
        "contents": "Welcome to Loom — 1‑click, no CLI needed.\n\nInitialize this folder to create your doc workspace (`.loom/`, `.mcp.json`, and the AI session rules).\n\n[Initialize Loom](command:loom.install.runInstall)\n\n[Open the Get Started walkthrough](command:loom.openWalkthrough)",
        "when": "!loom.workspaceInitialized"
      },
      {
        "view": "loom.threads",
        "contents": "No weaves yet.\n\nA weave groups related work (idea → design → plan → done).\n\n[Create Weave](command:loom.createWeave)\n\nNew to Loom? See the whole shape at once:\n\n[Start with an example](command:loom.seedExample)",
        "when": "loom.workspaceInitialized && !loom.hasWeaves"
      }
    ],
    "commands": [
      {
        "command": "loom.refresh",
        "title": "Refresh",
        "category": "Loom",
        "icon": "$(refresh)"
      },
      {
        "command": "loom.reconnectMcp",
        "title": "Reconnect MCP",
        "category": "Loom",
        "icon": "$(debug-restart)"
      },
      {
        "command": "loom.sendFeedback",
        "title": "Send Feedback",
        "category": "Loom",
        "icon": "$(feedback)"
      },
      {
        "command": "loom.toggleTelemetry",
        "title": "Toggle Usage Telemetry",
        "category": "Loom",
        "icon": "$(pulse)"
      },
      {
        "command": "loom.createWeave",
        "title": "Create Weave",
        "category": "Loom",
        "icon": {
          "light": "media/icons/weave.svg",
          "dark": "media/icons/weave.svg"
        }
      },
      {
        "command": "loom.threadCreate",
        "title": "Create Thread",
        "category": "Loom",
        "icon": {
          "light": "media/icons/thread.svg",
          "dark": "media/icons/thread.svg"
        }
      },
      {
        "command": "loom.delete",
        "title": "Delete",
        "category": "Loom",
        "icon": "$(trash)"
      },
      {
        "command": "loom.archive",
        "title": "Archive",
        "category": "Loom",
        "icon": {
          "light": "media/icons/archive.svg",
          "dark": "media/icons/archive.svg"
        }
      },
      {
        "command": "loom.createIdea",
        "title": "Create Idea",
        "category": "Loom",
        "icon": {
          "light": "media/icons/idea.svg",
          "dark": "media/icons/idea.svg"
        }
      },
      {
        "command": "loom.createDesign",
        "title": "Create Design",
        "category": "Loom",
        "icon": {
          "light": "media/icons/design.svg",
          "dark": "media/icons/design.svg"
        }
      },
      {
        "command": "loom.createPlan",
        "title": "Create Plan",
        "category": "Loom",
        "icon": {
          "light": "media/icons/plan.svg",
          "dark": "media/icons/plan.svg"
        }
      },
      {
        "command": "loom.generateReq",
        "title": "Generate Requirements",
        "category": "Loom",
        "icon": "$(sparkle)"
      },
      {
        "command": "loom.finalizeReq",
        "title": "Finalize (Lock) Requirements",
        "category": "Loom",
        "icon": "$(lock)"
      },
      {
        "command": "loom.amendReq",
        "title": "Amend Requirements",
        "category": "Loom",
        "icon": "$(sync)"
      },
      {
        "command": "loom.verifyReq",
        "title": "Verify Thread Against Requirements",
        "category": "Loom",
        "icon": "$(verified)"
      },
      {
        "command": "loom.rename",
        "title": "Rename (title / folder)",
        "category": "Loom",
        "icon": "$(edit)"
      },
      {
        "command": "loom.renameFile",
        "title": "Rename File…",
        "category": "Loom"
      },
      {
        "command": "loom.refineDesign",
        "title": "Refine Design",
        "category": "Loom",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "loom.generateDesign",
        "title": "Generate Design (AI)",
        "category": "Loom",
        "icon": "$(sparkle)"
      },
      {
        "command": "loom.generatePlan",
        "title": "Generate Plan (AI)",
        "category": "Loom",
        "icon": "$(sparkle)"
      },
      {
        "command": "loom.startPlan",
        "title": "Start Plan",
        "category": "Loom",
        "icon": "$(play)"
      },
      {
        "command": "loom.completeStep",
        "title": "Complete Step",
        "category": "Loom",
        "icon": "$(pass)"
      },
      {
        "command": "loom.validate",
        "title": "Validate",
        "category": "Loom",
        "icon": "$(shield)"
      },
      {
        "command": "loom.setGrouping",
        "title": "Set Grouping",
        "category": "Loom",
        "icon": {
          "light": "media/icons/group.svg",
          "dark": "media/icons/group.svg"
        }
      },
      {
        "command": "loom.setTextFilter",
        "title": "Filter by text",
        "category": "Loom",
        "icon": "$(search)"
      },
      {
        "command": "loom.setStatusFilter",
        "title": "Filter by status",
        "category": "Loom",
        "icon": {
          "light": "media/icons/filter.svg",
          "dark": "media/icons/filter.svg"
        }
      },
      {
        "command": "loom.toggleArchived",
        "title": "Toggle Archived",
        "category": "Loom",
        "icon": {
          "light": "media/icons/archive.svg",
          "dark": "media/icons/archive.svg"
        }
      },
      {
        "command": "loom.toggleArchivedOff",
        "title": "Toggle Archived",
        "category": "Loom",
        "icon": "$(archive)"
      },
      {
        "command": "loom.chatNew",
        "title": "Create Chat",
        "category": "Loom",
        "icon": {
          "light": "media/icons/chat.svg",
          "dark": "media/icons/chat.svg"
        }
      },
      {
        "command": "loom.chatReply",
        "title": "AI Reply",
        "category": "Loom",
        "icon": "$(sparkle)"
      },
      {
        "command": "loom.restoreItem",
        "title": "Restore from Archive",
        "category": "Loom",
        "icon": "$(discard)"
      },
      {
        "command": "loom.setStatusDone",
        "title": "Set Status: Done",
        "category": "Loom",
        "icon": "$(pass-filled)"
      },
      {
        "command": "loom.setStatusActive",
        "title": "Set Status: Active",
        "category": "Loom",
        "icon": "$(circle-large-outline)"
      },
      {
        "command": "loom.promoteToIdea",
        "title": "Promote to Idea",
        "category": "Loom",
        "icon": {
          "light": "media/icons/idea.svg",
          "dark": "media/icons/idea.svg"
        }
      },
      {
        "command": "loom.promoteToDesign",
        "title": "Promote to Design",
        "category": "Loom",
        "icon": {
          "light": "media/icons/design.svg",
          "dark": "media/icons/design.svg"
        }
      },
      {
        "command": "loom.promoteToPlan",
        "title": "Promote to Plan",
        "category": "Loom",
        "icon": {
          "light": "media/icons/plan.svg",
          "dark": "media/icons/plan.svg"
        }
      },
      {
        "command": "loom.promoteToReference",
        "title": "Promote to Reference",
        "category": "Loom",
        "icon": "$(library)"
      },
      {
        "command": "loom.refineIdea",
        "title": "Refine Idea",
        "category": "Loom",
        "icon": "$(edit)"
      },
      {
        "command": "loom.refinePlan",
        "title": "Refine Plan",
        "category": "Loom",
        "icon": "$(edit)"
      },
      {
        "command": "loom.doStep",
        "title": "Do Step(s)",
        "category": "Loom",
        "icon": "$(sparkle)"
      },
      {
        "command": "loom.closePlan",
        "title": "Close Plan",
        "category": "Loom",
        "icon": "$(archive)"
      },
      {
        "command": "loom.context.exclude",
        "title": "Exclude from context",
        "category": "Loom",
        "icon": "$(circle-slash)"
      },
      {
        "command": "loom.context.include",
        "title": "Include in context",
        "category": "Loom",
        "icon": "$(check)"
      },
      {
        "command": "loom.context.reset",
        "title": "Reset to auto",
        "category": "Loom",
        "icon": "$(discard)"
      },
      {
        "command": "loom.context.openDoc",
        "title": "Open Document",
        "category": "Loom"
      },
      {
        "command": "loom.createReference",
        "title": "Create Reference",
        "category": "Loom",
        "icon": "$(library)"
      },
      {
        "command": "loom.addRequiresLoad",
        "title": "Add References…",
        "category": "Loom",
        "icon": "$(link)"
      },
      {
        "command": "loom.refreshCtx",
        "title": "Refresh Context",
        "category": "Loom",
        "icon": "$(sync)"
      },
      {
        "command": "loom.toggleSyncDocToTree",
        "title": "Sync Doc → Tree (enabled)",
        "category": "Loom",
        "icon": "$(eye)"
      },
      {
        "command": "loom.toggleSyncDocToTreeOff",
        "title": "Sync Doc → Tree (disabled)",
        "category": "Loom",
        "icon": "$(eye-closed)"
      },
      {
        "command": "loom.toggleRoadmap",
        "title": "Show Roadmap",
        "category": "Loom",
        "icon": "$(map)"
      },
      {
        "command": "loom.toggleRoadmapOff",
        "title": "Show Threads",
        "category": "Loom",
        "icon": "$(list-tree)"
      },
      {
        "command": "loom.selectHistoryGrouping",
        "title": "Group History By…",
        "category": "Loom",
        "icon": "$(tag)"
      },
      {
        "command": "loom.seedExample",
        "title": "Start with an Example",
        "category": "Loom",
        "icon": "$(rocket)"
      },
      {
        "command": "loom.setupAi",
        "title": "Set up AI",
        "category": "Loom",
        "icon": "$(sparkle)"
      },
      {
        "command": "loom.openWalkthrough",
        "title": "Open Get Started Walkthrough",
        "category": "Loom",
        "icon": "$(book)"
      }
    ],
    "configuration": {
      "title": "Loom",
      "properties": {
        "reslava-loom.user.name": {
          "type": "string",
          "default": "",
          "description": "Your display name used in chat and document headers (e.g. 'Rafa')."
        },
        "reslava-loom.ai.provider": {
          "type": "string",
          "enum": [
            "anthropic",
            "deepseek",
            "openai"
          ],
          "default": "anthropic",
          "description": "AI provider. Claude (Anthropic) is recommended. DeepSeek and OpenAI also supported."
        },
        "reslava-loom.ai.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the configured AI provider.",
          "markdownDescription": "API key for the configured AI provider. Store securely — do not commit to source control."
        },
        "reslava-loom.ai.model": {
          "type": "string",
          "default": "",
          "description": "Model name override. Leave blank to use the provider default (claude-haiku-4-5-20251001 / deepseek-chat / gpt-4o-mini)."
        },
        "reslava-loom.ai.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL override for OpenAI-compatible endpoints. Leave blank to use provider default."
        },
        "reslava-loom.telemetry.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Opt in to anonymous, content-free usage telemetry: which commands run and where the workflow stalls — never your documents, titles, paths, or any PII. Off by default. See the README for the exact event list."
        }
      }
    },
    "walkthroughs": [
      {
        "id": "loom.getStarted",
        "title": "Get Started with Loom",
        "description": "1‑click, document‑driven AI workflow — no CLI, no setup.",
        "steps": [
          {
            "id": "initWorkspace",
            "title": "Initialize Loom (1 click)",
            "description": "Create your doc workspace — no CLI, no Node, no terminal.\n[Initialize Loom](command:loom.install.runInstall)",
            "completionEvents": [
              "onContext:loom.workspaceInitialized"
            ],
            "media": {
              "markdown": "walkthroughs/01-initialize.md"
            }
          },
          {
            "id": "setupAi",
            "title": "Connect an AI (optional)",
            "description": "Claude Code is recommended — no API key needed. Or set an API key.\n[Set up AI](command:loom.setupAi)",
            "completionEvents": [
              "onContext:loom.aiConfigured"
            ],
            "media": {
              "markdown": "walkthroughs/02-connect-ai.md"
            }
          },
          {
            "id": "firstWeave",
            "title": "Create your first weave",
            "description": "Group your work into a weave — or seed a ready‑made example to see the shape.\n[Create Weave](command:loom.createWeave)\n[Start with an example](command:loom.seedExample)",
            "completionEvents": [
              "onContext:loom.hasWeaves"
            ],
            "media": {
              "markdown": "walkthroughs/03-first-weave.md"
            }
          },
          {
            "id": "runLoop",
            "title": "Run the loop",
            "description": "Chat → Generate Idea → Design → Plan → Do Step. Every stage is a Markdown doc the AI reads and writes.",
            "media": {
              "markdown": "walkthroughs/04-run-the-loop.md"
            }
          }
        ]
      }
    ],
    "keybindings": [
      {
        "command": "loom.rename",
        "key": "f2",
        "when": "focusedView == loom.threads"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "loom.toggleRoadmap",
          "when": "view == loom.threads && loom.workspaceInitialized && !loom.roadmapEnabled",
          "group": "navigation@0"
        },
        {
          "command": "loom.toggleRoadmapOff",
          "when": "view == loom.threads && loom.roadmapEnabled",
          "group": "navigation@0"
        },
        {
          "command": "loom.selectHistoryGrouping",
          "when": "view == loom.threads && loom.roadmapEnabled",
          "group": "navigation@01"
        },
        {
          "command": "loom.createWeave",
          "when": "view == loom.threads && loom.workspaceInitialized && !loom.roadmapEnabled",
          "group": "navigation@1"
        },
        {
          "command": "loom.setGrouping",
          "when": "view == loom.threads && !loom.roadmapEnabled",
          "group": "navigation@2"
        },
        {
          "command": "loom.setStatusFilter",
          "when": "view == loom.threads",
          "group": "navigation@3"
        },
        {
          "command": "loom.setTextFilter",
          "when": "view == loom.threads && !loom.roadmapEnabled",
          "group": "navigation@4"
        },
        {
          "command": "loom.toggleArchived",
          "when": "view == loom.threads && loom.showArchived",
          "group": "navigation@5"
        },
        {
          "command": "loom.toggleArchivedOff",
          "when": "view == loom.threads && !loom.showArchived",
          "group": "navigation@5"
        },
        {
          "command": "loom.toggleSyncDocToTree",
          "when": "view == loom.threads && loom.syncDocToTreeEnabled",
          "group": "navigation@6"
        },
        {
          "command": "loom.toggleSyncDocToTreeOff",
          "when": "view == loom.threads && !loom.syncDocToTreeEnabled",
          "group": "navigation@6"
        },
        {
          "command": "loom.refresh",
          "when": "view == loom.threads",
          "group": "navigation@7"
        }
      ],
      "view/item/context": [
        {
          "command": "loom.context.exclude",
          "when": "view == loom.context && viewItem =~ /^ctx-(auto|locked)$/",
          "group": "inline"
        },
        {
          "command": "loom.context.include",
          "when": "view == loom.context && viewItem =~ /^ctx-(excluded|available)$/",
          "group": "inline"
        },
        {
          "command": "loom.context.reset",
          "when": "view == loom.context && viewItem =~ /^ctx-(pinned|excluded|required)$/",
          "group": "inline"
        },
        {
          "command": "loom.chatNew",
          "when": "view == loom.threads && viewItem == chats-section",
          "group": "inline@1"
        },
        {
          "command": "loom.refreshCtx",
          "when": "view == loom.threads && viewItem == ctx-section",
          "group": "inline@1"
        },
        {
          "command": "loom.createReference",
          "when": "view == loom.threads && viewItem == refs-section",
          "group": "inline@1"
        },
        {
          "command": "loom.addRequiresLoad",
          "when": "view == loom.threads && viewItem =~ /^(idea|design|plan)/",
          "group": "edit@0"
        },
        {
          "command": "loom.createIdea",
          "when": "view == loom.threads && viewItem =~ /^thread/ && !(viewItem =~ /has-idea/)",
          "group": "inline@1"
        },
        {
          "command": "loom.createDesign",
          "when": "view == loom.threads && viewItem =~ /^thread/ && !(viewItem =~ /has-design/)",
          "group": "inline@2"
        },
        {
          "command": "loom.createPlan",
          "when": "view == loom.threads && (viewItem =~ /^thread/ || viewItem == design)",
          "group": "inline@3"
        },
        {
          "command": "loom.generateReq",
          "when": "view == loom.threads && viewItem =~ /^thread/ && !(viewItem =~ /has-req/)",
          "group": "inline@0"
        },
        {
          "command": "loom.finalizeReq",
          "when": "view == loom.threads && viewItem == req-temp",
          "group": "inline@1"
        },
        {
          "command": "loom.amendReq",
          "when": "view == loom.threads && viewItem == req",
          "group": "inline@1"
        },
        {
          "command": "loom.verifyReq",
          "when": "view == loom.threads && (viewItem == req || viewItem == req-temp)",
          "group": "inline@2"
        },
        {
          "command": "loom.createWeave",
          "when": "view == loom.threads && viewItem =~ /^weave/",
          "group": "create@1"
        },
        {
          "command": "loom.threadCreate",
          "when": "view == loom.threads && viewItem =~ /^weave/",
          "group": "create@2"
        },
        {
          "command": "loom.chatNew",
          "when": "view == loom.threads && viewItem =~ /^thread/",
          "group": "create@3"
        },
        {
          "command": "loom.createIdea",
          "when": "view == loom.threads && viewItem =~ /^thread/ && !(viewItem =~ /has-idea/)",
          "group": "create@1"
        },
        {
          "command": "loom.createDesign",
          "when": "view == loom.threads && viewItem =~ /^thread/ && !(viewItem =~ /has-design/)",
          "group": "create@2"
        },
        {
          "command": "loom.createPlan",
          "when": "view == loom.threads && (viewItem =~ /^thread/ || viewItem == design)",
          "group": "create@3"
        },
        {
          "command": "loom.generateReq",
          "when": "view == loom.threads && viewItem =~ /^thread/ && !(viewItem =~ /has-req/)",
          "group": "create@0"
        },
        {
          "command": "loom.finalizeReq",
          "when": "view == loom.threads && viewItem == req-temp",
          "group": "edit@1"
        },
        {
          "command": "loom.amendReq",
          "when": "view == loom.threads && viewItem == req",
          "group": "edit@1"
        },
        {
          "command": "loom.verifyReq",
          "when": "view == loom.threads && (viewItem == req || viewItem == req-temp)",
          "group": "edit@2"
        },
        {
          "command": "loom.startPlan",
          "when": "view == loom.threads && viewItem =~ /^plan-(draft|active)$/",
          "group": "inline@1"
        },
        {
          "command": "loom.doStep",
          "when": "view == loom.threads && viewItem == plan-implementing-doable",
          "group": "inline@1"
        },
        {
          "command": "loom.completeStep",
          "when": "view == loom.threads && viewItem == plan-implementing-doable",
          "group": "inline@2"
        },
        {
          "command": "loom.chatReply",
          "when": "view == loom.threads && viewItem =~ /^chat(-refs)?$/",
          "group": "inline@1"
        },
        {
          "command": "loom.validate",
          "when": "view == loom.threads && viewItem =~ /^weave/",
          "group": "inline@2"
        },
        {
          "command": "loom.refineIdea",
          "when": "view == loom.threads && viewItem =~ /^(idea|loose-idea)/",
          "group": "ai@1"
        },
        {
          "command": "loom.generateDesign",
          "when": "view == loom.threads && viewItem =~ /^idea/",
          "group": "ai@2"
        },
        {
          "command": "loom.refineDesign",
          "when": "view == loom.threads && viewItem == design",
          "group": "ai@1"
        },
        {
          "command": "loom.generatePlan",
          "when": "view == loom.threads && viewItem == design",
          "group": "ai@2"
        },
        {
          "command": "loom.refinePlan",
          "when": "view == loom.threads && viewItem =~ /^plan-/",
          "group": "ai@1"
        },
        {
          "command": "loom.closePlan",
          "when": "view == loom.threads && viewItem =~ /^plan-(implementing|done)$/",
          "group": "ai@2"
        },
        {
          "command": "loom.promoteToIdea",
          "when": "view == loom.threads && viewItem == chat",
          "group": "ai@1"
        },
        {
          "command": "loom.promoteToDesign",
          "when": "view == loom.threads && viewItem =~ /^(chat|idea|loose-idea)/",
          "group": "ai@2"
        },
        {
          "command": "loom.promoteToPlan",
          "when": "view == loom.threads && viewItem =~ /^(chat|idea|loose-idea|design)/",
          "group": "ai@3"
        },
        {
          "command": "loom.promoteToReference",
          "when": "view == loom.threads && viewItem == chat-refs",
          "group": "ai@1"
        },
        {
          "command": "loom.restoreItem",
          "when": "view == loom.threads && viewItem == archived",
          "group": "edit@0"
        },
        {
          "command": "loom.setStatusDone",
          "when": "view == loom.threads && viewItem =~ /^(idea|design|plan|chat|reference)/",
          "group": "edit@1"
        },
        {
          "command": "loom.setStatusActive",
          "when": "view == loom.threads && viewItem =~ /^(idea|design|plan|chat|reference)/",
          "group": "edit@2"
        },
        {
          "command": "loom.rename",
          "when": "view == loom.threads && viewItem =~ /^(weave|thread|idea|design|plan|chat|done|ctx|loose|reference)/",
          "group": "edit@3"
        },
        {
          "command": "loom.renameFile",
          "when": "view == loom.threads && viewItem =~ /^reference/",
          "group": "edit@3"
        },
        {
          "command": "loom.archive",
          "when": "view == loom.threads && viewItem =~ /^(weave|thread|reference|chat-refs)/",
          "group": "edit@4"
        },
        {
          "command": "loom.delete",
          "when": "view == loom.threads && (viewItem == archived || (viewItem =~ /^(weave|thread|idea|design|plan|chat|done|ctx|loose|reference)/ && !(viewItem =~ /-archived/)))",
          "group": "edit@5"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc -p ./ --noEmit",
    "package": "npx @vscode/vsce package --no-dependencies",
    "publish": "npx @vscode/vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@reslava-loom/app": "file:../app",
    "@reslava-loom/core": "file:../core",
    "@reslava-loom/fs": "file:../fs",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.5.0"
  }
}
