{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2020",
        "outDir": "out",
        "rootDir": ".",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "types": ["mocha", "node"]
    },
    "include": ["./**/*.ts"],
    "exclude": ["node_modules", "out"]
}
